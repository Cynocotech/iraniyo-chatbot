# Copy this file to .env and fill in real values.
# This service powers the Iraniyo chat widget (replaces the old n8n workflow).

# ── Required for chat generation ──────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Required for Dr. Yas RAG (Qdrant vector search) ───────
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
QDRANT_URL=https://irdb.iraniu.uk
QDRANT_API_KEY=
QDRANT_COLLECTION=app_posts
SCORE_THRESHOLD=0.50
TOP_K=5

# ── Optional: persistent storage (chat memory, run log, leads) ──
# Leave empty to use in-memory/CSV fallbacks (reset on restart)
# Local dev (via `docker compose up -d postgres`):
#   POSTGRES_DSN=postgresql://iraniano:iraniano@localhost:5433/iraniano
# (port 5433 avoids clashing with a host Postgres already on 5432)
# When running the dryas service itself via docker-compose, use the
# service name + in-container port:
#   POSTGRES_DSN=postgresql://iraniano:iraniano@postgres:5432/iraniano
POSTGRES_DSN=
MAX_HISTORY=10

# ── Postgres container settings (used by docker-compose) ──
POSTGRES_USER=iraniano
POSTGRES_PASSWORD=iraniano
POSTGRES_DB=iraniano
POSTGRES_PORT=5433

# ── Used to build share links in Dr. Yas answers ──────────
APP_BASE_URL=https://app.iraniu.uk

# ── Optional: SMTP (end-of-chat transcript email) ─────────
# Leave empty to disable the "End chat" email feature
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ایرانیو
SMTP_USE_TLS=true

# ── Server port (used by docker-compose) ──────────────────
PORT=8000
